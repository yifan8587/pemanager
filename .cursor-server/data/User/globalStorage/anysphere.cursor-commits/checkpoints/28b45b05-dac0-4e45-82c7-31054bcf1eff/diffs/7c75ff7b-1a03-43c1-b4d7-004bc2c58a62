{"fsPath":"/root/pemanager/backend/routemanage/services/netplan_routes.py","fileUuid":"7c75ff7b-1a03-43c1-b4d7-004bc2c58a62","fileSizeBytes":18413,"numLines":555,"diffChanges":[{"originalStartLineNumberOneIndexed":243,"originalEndLineNumberExclusiveOneIndexed":243,"modifiedStartLineNumberOneIndexed":243,"modifiedEndLineNumberExclusiveOneIndexed":301,"addedLines":["","def kernel_remove_routes(snapshots: list[dict[str, Any]] | None) -> list[dict[str, Any]]:","    \"\"\"","    对路由快照列表执行 `ip route del`（best-effort）。","","    snapshots: 由 resourcemanage._delete_linked_route_intents 等返回的字典列表，元素至少含：","        - interface_name","        - dest_cidr","        - gateway (可空)","        - route_table (可空)","","    返回每一步的执行结果：[{argv, ok, stderr, benign}, ...]。","    \"benign=True\" 表示内核中本来就没有这条路由（视为成功）。","    \"\"\"","    import ipaddress as _ip","","    steps: list[dict[str, Any]] = []","    for r in (snapshots or []):","        dest = (r.get('dest_cidr') or '').strip()","        if not dest:","            continue","        try:","            if dest.lower() == 'default':","                fam_num = 4","            else:","                fam_num = _ip.ip_network(dest, strict=False).version","        except Exception:","            fam_num = 4","        fam = '-4' if fam_num == 4 else '-6'","","        argv = ['ip', fam, 'route', 'del', dest]","        gw = r.get('gateway')","        if gw:","            argv += ['via', str(gw)]","        ifn = (r.get('interface_name') or '').strip()","        if ifn:","            argv += ['dev', ifn]","        if r.get('route_table') is not None:","            argv += ['table', str(int(r['route_table']))]","","        res = _run(argv, timeout_kind='apply')","        err = (res.stderr or '').lower()","        benign = (","            not res.ok","            and (","                'no such process' in err","                or 'no such file or directory' in err","                or 'cannot find device' in err  # 接口已不存在，路由必然也没了","            )","        )","        steps.append({","            'argv': argv,","            'ok': bool(res.ok or benign),","            'stderr': res.stderr,","            'benign': bool(benign),","        })","    return steps",""],"tokenizedAddedLines":[4,1000375,89,1000376,4,1000377,1000378,1000379,1000380,1000381,4,1000382,1000383,89,175,4,206,1000384,1000385,114,101,325,1000386,232,1000387,1000388,1000389,227,233,4,1000390,1000391,1000392,1000393,1000394,264,265,1000395,1000396,4,270,1000397,1000398,1000399,1000400,1000401,1000402,1000403,112,319,1000404,274,1000405,276,1000406,1000407,1000408,4]}],"gitInfo":{"gitInfo":{"gitRoot":"/root","branch":"main","commitHash":"7f968776a8c9f2f3ece70a1ea21dec564bc70561"}},"kind":"KIND_MODIFIED"}