                :closable="false"
                show-icon
                style="margin-bottom: 6px"
              />

              <el-form-item label="YAML 预览" class="yaml-wrap">
                <el-input
                  v-model="previewYaml"
                  type="textarea"
                  :rows="14"
                  readonly
