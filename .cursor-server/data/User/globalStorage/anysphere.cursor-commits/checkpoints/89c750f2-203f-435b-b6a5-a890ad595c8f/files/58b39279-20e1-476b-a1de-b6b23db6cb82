                  class="mono"
                />
              </el-form-item>

              <el-collapse v-if="lastApplyResult">
                <el-collapse-item title="最近一次下发结果（raw）" name="1">
                  <pre class="raw">{{ JSON.stringify(lastApplyResult, null, 2) }}</pre>
                </el-collapse-item>
              </el-collapse>
            </el-card>
          </el-col>

          <el-col :xs="24" :md="10">
