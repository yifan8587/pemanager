{"fsPath":"/root/pemanager/deploy/templates/nginx-pemanager.conf","fileUuid":"3c964b12-712a-4313-9335-08f3a58b53ef","fileSizeBytes":2265,"numLines":77,"diffChanges":[{"originalStartLineNumberOneIndexed":1,"originalEndLineNumberExclusiveOneIndexed":2,"modifiedStartLineNumberOneIndexed":1,"modifiedEndLineNumberExclusiveOneIndexed":78,"addedLines":["##","## PE Manager — nginx 站点配置","##","## - 80 端口对外；如启用 HTTPS，请在 deploy.md 的\"启用 HTTPS（Let's Encrypt）\"小节","##   按指引追加 443 server 块。","## - 静态前端在 /opt/pemanager/frontend/dist/","## - /api/ 反代到 Gunicorn unix socket","## - /static/ 反代到 collectstatic 输出目录（admin / DRF 自带静态）","##","","upstream pemanager_backend {","    server unix:/run/pemanager/backend.sock fail_timeout=0;","}","","server {","    listen 80 default_server;","    listen [::]:80 default_server;","    # 部署后可改为实际域名，例如 server_name pe.example.com;","    server_name _;","","    # 大量路由 / netplan YAML 预览可能有较大 payload","    client_max_body_size 16M;","    client_body_buffer_size 1M;","","    access_log /var/log/pemanager/nginx-access.log;","    error_log  /var/log/pemanager/nginx-error.log;","","    # ---- 前端 SPA（Vue history 模式 fallback 到 index.html）----","    root __PEM_INSTALL_DIR__/frontend/dist;","    index index.html;","","    location / {","        try_files $uri $uri/ /index.html;","    }","","    # 静态资源开启长缓存（带哈希文件名，安全）","    location ~* \\.(?:js|css|woff2?|ttf|otf|eot|ico|png|jpg|jpeg|gif|svg|webp)$ {","        expires 30d;","        add_header Cache-Control \"public, immutable\";","        try_files $uri =404;","    }","","    # ---- Django admin / DRF 静态文件 ----","    location /static/ {","        alias __PEM_STATIC_ROOT__/;","        expires 7d;","        add_header Cache-Control \"public\";","    }","","    # ---- API 反代 ----","    location /api/ {","        proxy_pass http://pemanager_backend;","        proxy_http_version 1.1;","        proxy_set_header Host              $host;","        proxy_set_header X-Real-IP         $remote_addr;","        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;","        proxy_set_header X-Forwarded-Proto $scheme;","        proxy_set_header Connection        \"\";","        # 立即下发 / mtr / 长 ping 可能耗时较久；放宽超时","        proxy_read_timeout  300s;","        proxy_send_timeout  300s;","        proxy_connect_timeout 10s;","        # 关闭缓冲，便于 SSE / 长连接（如未来引入）","        proxy_buffering off;","    }","","    # ---- Django admin ----","    location /admin/ {","        proxy_pass http://pemanager_backend;","        proxy_http_version 1.1;","        proxy_set_header Host              $host;","        proxy_set_header X-Real-IP         $remote_addr;","        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;","        proxy_set_header X-Forwarded-Proto $scheme;","    }","}",""],"tokenizedAddedLines":[1000001,1000002,1000001,1000003,1000004,1000005,1000006,1000007,1000001,1,1000008,1000009,1000010,1,1000011,1000012,1000013,1000014,1000015,1,1000016,1000017,1000018,1,1000019,1000020,1,1000021,1000022,1000023,1,1000024,1000025,1000026,1,1000027,1000028,1000029,1000030,1000031,1000026,1,1000032,1000033,1000034,1000035,1000036,1000026,1,1000037,1000038,1000039,1000040,1000041,1000042,1000043,1000044,1000045,1000046,1000047,1000048,1000049,1000050,1000051,1000026,1,1000052,1000053,1000039,1000040,1000041,1000042,1000043,1000044,1000026,1000010,1]}],"gitInfo":{"gitInfo":{"gitRoot":"/root","branch":"main","commitHash":"fa85d731dc8493d3c8eff21e0420f29d325ecf4e"}},"kind":"KIND_MODIFIED"}