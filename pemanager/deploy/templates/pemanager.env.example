# =============================================================================
# PE Manager 运行环境配置（生产）
#
# 部署后请将本文件复制到 /etc/pemanager/pemanager.env 并按需修改。
# systemd 单元 pemanager-backend.service / pemanager-monitor.service 会自动
# EnvironmentFile= 加载本文件。
# =============================================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_DEBUG=0
# !!! 部署时 deploy.sh 会自动生成一个高强度随机串覆盖本行；切勿在多台机器复用 !!!
DJANGO_SECRET_KEY=please-replace-me-with-random-50-chars
# 多个域名/IP 用英文逗号分隔；建议至少包含部署机的 IP 与对外域名
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# sqlite 数据库文件路径；如改为 /var/lib/pemanager 之外位置请同步授权
DJANGO_DB_PATH=/var/lib/pemanager/db.sqlite3
# collectstatic 输出目录（admin 静态文件由 nginx 反代）
DJANGO_STATIC_ROOT=/var/lib/pemanager/static

# --- CORS（仅当前端与后端跨域时需要追加；同源部署可留空）---
# 多个 origin 用英文逗号分隔，例如 https://pe.example.com,https://ops.example.com
PEMANAGER_EXTRA_ORIGINS=

# --- 默认管理员（首次 migrate 后由 post_migrate 信号自动创建）---
PEMANAGER_ADMIN_USERNAME=admin
PEMANAGER_ADMIN_PASSWORD=admin123
PEMANAGER_ADMIN_EMAIL=admin@pemanager.local

# --- JWT 生命周期 ---
PEM_ACCESS_TTL_HOURS=8
PEM_REFRESH_TTL_DAYS=14

# --- 系统下发开关（全部默认开启；如需"只读演示"可置为 0）---
INTERFACEMANAGE_NETPLAN_WRITE_ENABLED=1
INTERFACEMANAGE_WG_APPLY_ENABLED=1
ROUTEMANAGE_NETPLAN_WRITE_ENABLED=1
ROUTEMANAGE_IPROUTE_WRITE_ENABLED=1
ROUTEMANAGE_IPRULE_WRITE_ENABLED=1
QOSMANAGE_APPLY_ENABLED=1
FIREWALLMANAGE_APPLY_ENABLED=1
LOGMANAGE_JOURNAL_ENABLED=1

# --- 运维监控调度器：是否随后端进程自启 ---
# 默认 0：使用独立的 pemanager-monitor.service 负责采样调度（推荐）
OPERATION_SCHEDULER_AUTOSTART=0

# --- 系统命令前缀：用于"非 root 模式" ---
# 当 pemanager 以非 root 运行时，需要把以下前缀设为 "sudo -n"，并把对应
# sudoers fragment 安装到 /etc/sudoers.d/pemanager（deploy.sh 已自动处理）
# 默认部署是 "以 root 运行"，下列保持空即可。
INTERFACEMANAGE_NETPLAN_CMD_PREFIX=
QOSMANAGE_CMD_PREFIX=
FIREWALLMANAGE_CMD_PREFIX=
LOGMANAGE_JOURNAL_CMD_PREFIX=

# --- 路径自定义（默认即可） ---
INTERFACEMANAGE_NETPLAN_FRAGMENT_FILE=/etc/netplan/99-pemanager-tunnels.yaml
INTERFACEMANAGE_NETPLAN_WG_FRAGMENT_FILE=/etc/netplan/99-pemanager-wireguard.yaml
INTERFACEMANAGE_WG_CONFIG_DIR=/etc/wireguard
ROUTEMANAGE_NETPLAN_FRAGMENT_FILE=/etc/netplan/99-pemanager-routes.yaml
